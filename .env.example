# Supabase — get these from your project dashboard at supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key — for server-side/cron access (Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend — get from resend.com (for survey emails)
RESEND_API_KEY=re_your_key_here
RESEND_FROM_EMAIL=onboarding@resend.dev

# Anthropic — get from console.anthropic.com (powers AI Insights on Analytics).
# Optional: if unset, the app falls back to the built-in rule-based insights.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Sentry error tracking (optional). Get the DSN from your Sentry project
# (Settings → Client Keys (DSN)). Both are no-ops if unset.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Only needed to upload source maps during the build (Sentry → Settings):
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# App URL (used for email links and survey URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron secret — authenticates the Vercel Cron endpoint (any random string)
CRON_SECRET=your-random-secret-here

# Salt for hashing IPs in rate limiting. Keep separate from CRON_SECRET so you
# can rotate either independently. Falls back to CRON_SECRET if unset.
RATE_LIMIT_SALT=your-random-rate-limit-salt

# Required to use the one-time POST /api/setup/owner route. The route is
# DISABLED unless this is set, and the request must include { "secret": "<this>" }.
# Use a long random string; you can unset it again after claiming ownership.
SETUP_SECRET=your-random-setup-secret

# Paddle Billing — get from vendors.paddle.com
# Environment: "sandbox" for testing, "production" for live
PADDLE_API_KEY=your-paddle-api-key
PADDLE_ENVIRONMENT=sandbox
PADDLE_WEBHOOK_SECRET=your-webhook-signing-secret

# Paddle Price IDs — create products + prices in your Paddle dashboard
PADDLE_PRICE_STARTER=pri_your_starter_price_id
PADDLE_PRICE_GROWTH=pri_your_growth_price_id
PADDLE_PRICE_ENTERPRISE=pri_your_enterprise_price_id
