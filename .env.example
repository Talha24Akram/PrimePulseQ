# Supabase — get these from your project dashboard at supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key — for server-side/cron access (Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend — get from resend.com (for survey emails)
RESEND_API_KEY=re_your_key_here
RESEND_FROM_EMAIL=onboarding@resend.dev

# App URL (used for email links and survey URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron secret — any random string, add same value to Vercel env vars
CRON_SECRET=your-random-secret-here

# Optional: gate the one-time POST /api/setup/owner route. If set, the request
# must include { "secret": "<this value>" }. Leave unset to allow the first
# authenticated signup to claim ownership.
SETUP_SECRET=

# Paddle Billing — get from vendors.paddle.com
# Environment: "sandbox" for testing, "production" for live
PADDLE_API_KEY=your-paddle-api-key
PADDLE_ENVIRONMENT=sandbox
PADDLE_WEBHOOK_SECRET=your-webhook-signing-secret

# Paddle Price IDs — create products + prices in your Paddle dashboard
PADDLE_PRICE_STARTER=pri_your_starter_price_id
PADDLE_PRICE_GROWTH=pri_your_growth_price_id
PADDLE_PRICE_ENTERPRISE=pri_your_enterprise_price_id
